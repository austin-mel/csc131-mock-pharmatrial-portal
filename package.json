{
	"name": "backend",
  	"version": "1.0.0",
  	"main": "dist/index.js",
  	"type": "commonjs",
  	"scripts": {
    	"dev": "ts-node-dev src/server.ts",
    	"build": "tsc",
    	"start": "node dist/server.js",
  		"prisma:dev": "prisma migrate dev --schema=./prisma/schema.prisma --env-file=./environment/back-end.env",
  		"prisma:generate": "prisma generate --schema=./prisma/schema.prisma --env-file=./environment/back-end.env"
  },
	"dependencies": {
		"@prisma/client": "^6.17.1",
		"cors": "^2.8.5",
		"dotenv": "^17.2.3",
		"express": "^5.1.0"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.3",
		"@types/node": "^24.9.1",
		"prisma": "^6.17.1",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.9.3"
	}
}
