datasource db {
  provider = "postgresql"
  url      = env("BACK_END_HOST")
}

generator client {
  provider = "prisma-client-js"
}

model PortalUser {
  id           String   @id @default(uuid())
  portalId     String   @map("portal_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  role         String
  organization String
  createdAt    DateTime @default(now()) @map("created_at")
  audits       AuditEvent[]

  @@index([portalId])
  @@map("portal_users")
}

model Trial {
  id                String       @id @default(uuid())
  name              String
  drug              String
  phase             String
  condition         String
  start             DateTime
  end               DateTime
  enrollmentTarget  Int          @map("enrollment_target")
  status            String       @default("pending-approval")
  statusLabel       String?      @map("status_label")
  archived          Boolean      @default(false)
  createdAt         DateTime     @default(now()) @map("created_at")
  approvals         Json
  batchSubmitted    Boolean      @default(false) @map("batch_submitted")
  assignmentsLocked Boolean      @default(false) @map("assignments_locked")
  notifiedFDA       Boolean      @default(false) @map("notified_fda")
  disclosed         Boolean      @default(false)
  dosesPerPatient   Int          @default(1) @map("doses_per_patient")
  description       String?
  eligibility       Json?
  enrollments       Enrollment[]
  batch             Batch?
  assignments       Assignment[]
  reports           TrialReport[]

  @@index([status, archived])
  @@map("trials")
}

model Patient {
  id          String       @id @default(uuid())
  name        String
  dob         DateTime
  icdCodes    Json         @map("icd_codes")
  bloodType   String       @map("blood_type")
  bp          String?
  oxygen      Int?
  meds        String?
  allergy     String?
  height      Float?
  weight      Float?
  address     String?
  insuranceId String?      @map("insurance_id")
  employment  String?
  temperature String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  enrollments Enrollment[]

  @@map("patients")
}

model Enrollment {
  id           String        @id @default(uuid())
  trialId      String        @map("trial_id")
  patientId    String        @map("patient_id")
  eligible     Boolean       @default(false)
  doses        Int           @default(0)
  createdAt    DateTime      @default(now()) @map("created_at")
  trial        Trial         @relation(fields: [trialId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  assignment   Assignment?

  @@unique([trialId, patientId])
  @@index([patientId])
  @@map("enrollments")
}

model Appointment {
  id              String     @id @default(uuid())
  enrollmentId    String     @map("enrollment_id")
  date            DateTime
  time            String?
  type            String
  dose            Boolean    @default(false)
  bloodTestLevel  Float?     @map("blood_test_level")
  adverseEvents   Json       @map("adverse_events")
  note            String
  createdAt       DateTime   @default(now()) @map("created_at")
  enrollment      Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@map("appointments")
}

model Batch {
  id              String   @id @default(uuid())
  trialId         String   @unique @map("trial_id")
  batchRef        String   @map("batch_ref")
  treatmentPct    Int      @map("treatment_pct")
  manufactureDate DateTime? @map("manufacture_date")
  lotNumber       String?  @map("lot_number")
  shippingNotes   String?  @map("shipping_notes")
  submittedAt     DateTime @default(now()) @map("submitted_at")
  trial           Trial    @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@map("batches")
}

model Assignment {
  id           String     @id @default(uuid())
  trialId      String     @map("trial_id")
  enrollmentId String     @unique @map("enrollment_id")
  patientId    String     @map("patient_id")
  drug         String
  trackingId   String     @map("tracking_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  trial        Trial      @relation(fields: [trialId], references: [id], onDelete: Cascade)
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([trialId, patientId])
  @@index([trialId])
  @@map("assignments")
}

model TrialReport {
  id        String   @id @default(uuid())
  trialId   String   @map("trial_id")
  rows      Json
  createdAt DateTime @default(now()) @map("created_at")
  trial     Trial    @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@index([trialId])
  @@map("trial_reports")
}

model AuditEvent {
  id        String     @id @default(uuid())
  actorId   String?    @map("actor_id")
  actorRole String     @map("actor_role")
  action    String
  entityId  String     @map("entity_id")
  entityType String    @map("entity_type")
  metadata  Json?
  createdAt DateTime   @default(now()) @map("created_at")
  actor     PortalUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorRole])
  @@map("audit_events")
}
