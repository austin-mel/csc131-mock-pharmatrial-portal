datasource db {
  provider = "postgresql"
  url      = env("BACK_END_HOST")
}

generator client {
  provider = "prisma-client-js"
}

// =========================================
// =============== TRIAL ===================
// =========================================
model Trial {
  id          String    @id @default(uuid())
  name        String
  drug_id     String
  status      String    @default("pending")
  active      Boolean   @default(false)
  completed   Boolean   @default(false)
  rejected    Boolean   @default(false)

  approvals   Json
  distributed Json
  patients    Patient[]

  @@index([id])
  @@map("trials") // map to lowercase table
}

// =========================================
// =============== PATIENT =================
// =========================================
model Patient {
  id            String   @id @default(uuid())
  first_name    String
  last_name     String
  study_id      String
  drug_id       String?
  dob           DateTime
  address       String
  insurance_num String
  height        Float
  weight        Float
  blood         String
  employed      Boolean
  insured       Boolean
  eligibility   Boolean
  dose          Float
  phone_number  String
  email         String

  trial         Trial       @relation(fields: [study_id], references: [id])
  allergies     Allergy[]
  medications   Medication[]
  history       History[]
  icdcodes      IcdCode[]
  appointments  Appointment[]

  @@index([id])
  @@map("patients")
}

// =========================================
// =============== ALLERGY =================
// =========================================
model Allergy {
  id         Int      @id @default(autoincrement())
  name       String
  reactions  String
  patient_id String
  patient    Patient  @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@map("allergies")
}

// =========================================
// =========== MEDICATION ==================
// =========================================
model Medication {
  id         Int      @id @default(autoincrement())
  name       String
  purpose    String
  patient_id String
  patient    Patient  @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@map("medications")
}

// =========================================
// ============== HISTORY ==================
// =========================================
model History {
  id         Int      @id @default(autoincrement())
  disease    String
  carrier    String
  patient_id String
  patient    Patient  @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@map("history")
}

// =========================================
// ============== ICD CODES ================
// =========================================
model IcdCode {
  id         Int      @id @default(autoincrement())
  code       String
  patient_id String
  patient    Patient  @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@map("icdcodes")
}

// =========================================
// ============= APPOINTMENT ===============
// =========================================
model Appointment {
  id         Int       @id @default(autoincrement())
  date       DateTime
  o2         Int
  bp         String
  temp       Float
  hiv        Int
  doctor     String
  notes      Json?
  patient_id String
  patient    Patient    @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@map("appointments")
}

// =========================================
// ================ USER ===================
// =========================================
model User {
  id           String   @id @default(uuid())
  first_name   String
  last_name    String
  phone_number String
  email        String
  role         String
  created_at   DateTime @default(now())

  @@map("users")
}